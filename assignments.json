<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Gráficos de barras</title>
  <style>
    :root { --navy:#04101c; --navy-2:#071827; --blue:#1b96bf; --ink:#eef7ff; --muted:#9fb2c7; --line:rgba(255,255,255,.12); --soft:rgba(255,255,255,.04); --yellow:#ffcf33; --danger:#ff5263; --radius:6px; }
    *{box-sizing:border-box}
    body{margin:0;font-family:Inter,system-ui,-apple-system,"Segoe UI",sans-serif;color:var(--ink);background:radial-gradient(circle at 14% 0%, rgba(27,150,191,.22), transparent 26%),linear-gradient(180deg,#02060b 0%,#000 100%);padding:16px 16px 40px;}
    .lesson{max-width:820px;margin:0 auto;display:grid;gap:14px}
    .hero{border-radius:var(--radius);padding:18px;background:linear-gradient(135deg,rgba(255,255,255,.05),rgba(255,255,255,.02)),linear-gradient(135deg,#0a2032,#04101c 68%,#000);border:1px solid rgba(255,255,255,.10);position:relative;overflow:hidden;box-shadow:0 18px 40px rgba(0,0,0,.28)}
    .hero:after{content:"";position:absolute;width:120px;height:120px;border:14px solid rgba(27,150,191,.12);border-radius:50%;right:-40px;top:-35px}
    .kicker{font-weight:900;color:#73ddff;letter-spacing:.08em;text-transform:uppercase;font-size:.78rem}
    .hero h1{margin:6px 0;font-size:clamp(1.7rem,9vw,3rem);line-height:.96;letter-spacing:-.06em}
    .hero p{margin:0;color:var(--muted);font-weight:650;line-height:1.45}
    .card{border:1px solid var(--line);border-radius:var(--radius);padding:16px;background:linear-gradient(135deg,rgba(255,255,255,.04),rgba(255,255,255,.02)),#07111b;box-shadow:0 12px 30px rgba(0,0,0,.22)}
    .card h2{margin:0 0 10px;font-size:1.2rem;letter-spacing:-.03em}
    .steps{display:grid;gap:10px;margin:0;padding:0;list-style:none}
    .steps li{display:grid;grid-template-columns:34px 1fr;gap:10px;align-items:start}
    .num{width:34px;height:34px;border-radius:var(--radius);background:linear-gradient(135deg,#2ba5ff,#0d76d8);color:#fff;display:grid;place-items:center;font-weight:900;box-shadow:0 10px 24px rgba(13,118,216,.24)}
    .formula{background:linear-gradient(135deg,#09233a,#061427);color:#fff;border-radius:var(--radius);padding:14px;font-weight:850;overflow:auto;border:1px solid rgba(93,173,255,.16)}
    .builder{display:grid;gap:12px}
    .row{display:grid;grid-template-columns:1fr 100px;gap:8px}
    .input{width:100%;border:1px solid var(--line);border-radius:var(--radius);padding:12px;background:#09131e;color:#fff;font:inherit}
    .btn{border:0;border-radius:var(--radius);padding:12px 14px;background:linear-gradient(135deg,#2ba5ff,#0d76d8);color:#fff;font-weight:900}
    .btn.secondary{background:#10273a;color:#9ce6ff;border:1px solid rgba(27,150,191,.24)}
    .btn.danger{background:#2a0e15;color:#ff98a2;border:1px solid rgba(255,82,99,.24)}
    canvas{width:100%;min-height:260px;border:1px solid rgba(93,173,255,.22);border-radius:var(--radius);background:linear-gradient(#07111b,#06101a)}
    .toolbar{display:flex;gap:8px;flex-wrap:wrap}
    .mini{font-size:.88rem;color:var(--muted);font-weight:650}
    .question{background:linear-gradient(135deg,rgba(255,207,51,.12),rgba(255,207,51,.06));border:1px solid rgba(255,207,51,.24);border-radius:var(--radius);padding:14px}
    .question strong{display:block;margin-bottom:4px;color:#ffe089}
    @media(min-width:720px){.builder-grid{display:grid;grid-template-columns:320px 1fr;gap:14px;align-items:start}.row{grid-template-columns:1fr 110px}}
  </style>
</head>
<body>
  <main class="lesson">
    <section class="hero">
      <div class="kicker">Estadística interactiva</div>
      <h1>Gráficos de barras</h1>
      <p>Un gráfico de barras sirve para comparar cantidades entre categorías. La altura de cada barra representa la frecuencia o el valor observado.</p>
    </section>

    <section class="card">
      <h2>Idea clave</h2>
      <ul class="steps">
        <li><span class="num">1</span><span>Define las categorías: por ejemplo frutas, deportes, respuestas o productos.</span></li>
        <li><span class="num">2</span><span>Cuenta la frecuencia o escribe el valor de cada categoría.</span></li>
        <li><span class="num">3</span><span>Dibuja barras proporcionales y deja claro el título, los ejes y la escala.</span></li>
      </ul>
    </section>

    <section class="card">
      <h2>Construye tu gráfico</h2>
      <p class="mini">Escribe una categoría y un valor. Luego presiona “Añadir”. Esta clase demuestra cómo pueden funcionar actividades dinámicas dentro del AVA.</p>
      <div class="builder-grid">
        <div class="builder">
          <div class="row">
            <input class="input" id="label" placeholder="Categoría" value="Café" />
            <input class="input" id="value" type="number" min="0" value="12" />
          </div>
          <div class="toolbar">
            <button class="btn" id="addBtn">Añadir</button>
            <button class="btn secondary" id="sampleBtn">Datos demo</button>
            <button class="btn danger" id="clearBtn">Limpiar</button>
          </div>
          <div class="formula">Escala visual: altura de la barra = valor ÷ valor máximo × altura disponible</div>
        </div>
        <canvas id="chart" width="720" height="430" aria-label="Gráfico de barras"></canvas>
      </div>
    </section>

    <section class="question">
      <strong>Pregunta rápida</strong>
      Si una barra tiene el doble de altura que otra, ¿qué puedes afirmar sobre sus valores? Explica con una frase, no solo con números.
    </section>
  </main>

  <script>
    const label = document.getElementById('label');
    const value = document.getElementById('value');
    const chart = document.getElementById('chart');
    const ctx = chart.getContext('2d');
    let data = [
      { label: 'Café', value: 12 },
      { label: 'Cacao', value: 8 },
      { label: 'Maíz', value: 15 }
    ];

    function draw() {
      const w = chart.width;
      const h = chart.height;
      ctx.clearRect(0, 0, w, h);
      ctx.fillStyle = '#07111b';
      ctx.fillRect(0, 0, w, h);
      const pad = 58;
      const max = Math.max(1, ...data.map(item => item.value));
      const plotW = w - pad * 1.4;
      const plotH = h - pad * 1.7;
      ctx.strokeStyle = 'rgba(255,255,255,.88)';
      ctx.lineWidth = 3;
      ctx.beginPath();
      ctx.moveTo(pad, 26);
      ctx.lineTo(pad, h - pad);
      ctx.lineTo(w - 28, h - pad);
      ctx.stroke();
      ctx.fillStyle = '#b6c4d4';
      ctx.font = 'bold 18px system-ui';
      ctx.fillText('Valor', 18, 32);
      ctx.fillText('Categorías', w - 145, h - 18);
      if (!data.length) {
        ctx.fillStyle = '#9fb2c7';
        ctx.font = 'bold 24px system-ui';
        ctx.fillText('Añade datos para ver el gráfico', 120, 210);
        return;
      }
      const gap = 18;
      const barW = Math.max(30, (plotW - gap * (data.length + 1)) / data.length);
      data.forEach((item, index) => {
        const x = pad + gap + index * (barW + gap);
        const barH = (item.value / max) * plotH;
        const y = h - pad - barH;
        const gradient = ctx.createLinearGradient(0, y, 0, h - pad);
        gradient.addColorStop(0, '#2ba5ff');
        gradient.addColorStop(1, '#0d76d8');
        ctx.fillStyle = gradient;
        roundRect(ctx, x, y, barW, barH, 14);
        ctx.fill();
        ctx.fillStyle = '#eef7ff';
        ctx.font = '900 20px system-ui';
        ctx.textAlign = 'center';
        ctx.fillText(item.value, x + barW / 2, y - 10);
        ctx.font = '800 16px system-ui';
        ctx.fillText(shorten(item.label), x + barW / 2, h - pad + 24);
        ctx.textAlign = 'left';
      });
    }

    function roundRect(ctx, x, y, width, height, radius) {
      const r = Math.min(radius, width / 2, height / 2);
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + width, y, x + width, y + height, r);
      ctx.arcTo(x + width, y + height, x, y + height, r);
      ctx.arcTo(x, y + height, x, y, r);
      ctx.arcTo(x, y, x + width, y, r);
      ctx.closePath();
    }

    function shorten(text) {
      return String(text).length > 10 ? String(text).slice(0, 9) + '…' : text;
    }

    document.getElementById('addBtn').addEventListener('click', () => {
      const cleanLabel = label.value.trim();
      const cleanValue = Number(value.value);
      if (!cleanLabel || Number.isNaN(cleanValue) || cleanValue < 0) return;
      data.push({ label: cleanLabel, value: cleanValue });
      label.value = '';
      value.value = '';
      label.focus();
      draw();
    });
    document.getElementById('sampleBtn').addEventListener('click', () => {
      data = [
        { label: 'Café', value: 18 },
        { label: 'Plátano', value: 9 },
        { label: 'Cacao', value: 13 },
        { label: 'Yuca', value: 7 }
      ];
      draw();
    });
    document.getElementById('clearBtn').addEventListener('click', () => { data = []; draw(); });
    draw();
  </script>
</body>
</html>
